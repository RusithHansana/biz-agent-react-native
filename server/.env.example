# Google service account JSON string used by backend integrations
GOOGLE_SERVICE_ACCOUNT_KEY=

# Vertex AI project and location (required when using GOOGLE_SERVICE_ACCOUNT_KEY for Gemini)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=

# Gemini API key (alternative to service account auth)
GEMINI_API_KEY=

# Gemini model and request timeout
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=15000

# Google Sheets document ID for storing booking data
SHEET_ID=

# Shared secret validated from X-API-Key request header
API_KEY=

# Rate limit requests per minute
RATE_LIMIT_RPM=

# Rate limit tokens per minute
RATE_LIMIT_TPM=

# Rate limit requests per day
RATE_LIMIT_RPD=
