# Public mobile runtime config (bundled into client app)
# Do not store secrets in EXPO_PUBLIC_* values.
#
# Use http://localhost:3000 for emulator dev against a local server.
# For physical devices, use the deployed Vercel URL instead:
EXPO_PUBLIC_API_BASE_URL=https://server-<your-vercel-project>.vercel.app
EXPO_PUBLIC_API_KEY=dev-mobile-key

# Server-only secrets belong in server/.env.example
# GOOGLE_SERVICE_ACCOUNT_KEY=
# SHEET_ID=
# API_KEY=
